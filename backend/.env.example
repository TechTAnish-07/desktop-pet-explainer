# Default LLM Provider & Model Configuration via LiteLLM
# LiteLLM supports model prefixes:
#   - gemini/gemini-2.5-flash (Google Gemini - Free Tier available)
#   - gemini/gemini-1.5-pro
#   - claude-3-5-sonnet-20241022 (Anthropic Claude)
#   - gpt-4o (OpenAI)
#   - ollama/llama3 (Local Ollama)
#   - mock (Built-in simulated explanation stream for testing)

DEFAULT_MODEL=gemini/gemini-2.5-flash

# API Keys (set the one corresponding to your chosen model, or pass from frontend UI settings)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Server configuration
PORT=8000
HOST=127.0.0.1
